#!/usr/bin/env bash

# A dmenu wrapper script for system functions.
case "$(readlink -f /sbin/init)" in
	*systemd*) ctl='systemctl' ;;
	*) ctl='loginctl' ;;
esac

case "$(printf "🔒 lock\n🚪 logout $WM\n♻️ renew $WM\n🔃 reboot\n🖥️ shutdown\n⏸️ suspend\n📺 display off" | rofi -dmenu -p Action)" in
	'🔒 lock') hyprlock ;;
	"🚪 logout $WM") hyprshutdown ;;
	"♻️ renew $WM") hyprctl reload;;
	'⏸️ suspend') $ctl suspend-then-hibernate -i ;;
	'🔃 reboot') hyprshutdown -t 'Restarting...' --post-cmd 'reboot' ;;
	'🖥️ shutdown') hyprshutdown -t 'Shutting down...' --post-cmd 'shutdown -P 0' ;;
	*) exit 1 ;;
esac
