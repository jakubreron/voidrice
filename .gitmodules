[submodule ".config/mpv/script_modules/mpvSockets"]
	path = .config/mpv/script_modules/mpvSockets
	url = https://github.com/wis/mpvSockets.git
[submodule ".config/mpv/scripts/autosubsync-mpv"]
	path = .config/mpv/scripts/autosubsync-mpv
	url = git@github.com:joaquintorres/autosubsync-mpv.git
[submodule ".config/alacritty/themes/alacritty-theme"]
	path = .config/alacritty/themes/alacritty-theme
	url = https://github.com/alacritty/alacritty-theme
[submodule ".config/firefox/betterfox"]
	path = .config/firefox/betterfox
	url = https://github.com/yokoffing/Betterfox.git
[submodule ".local/bin/lfimg"]
	path = .local/bin/lfimg
	url = https://github.com/jakubreron/lfimg
[submodule ".config/fcitx5/themes/fcitx5-gruvbox"]
	path = .config/fcitx5/themes/fcitx5-gruvbox
	url = https://github.com/ayamir/fcitx5-gruvbox.git
